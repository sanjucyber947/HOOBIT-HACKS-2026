# ---------------- HELPERS ---------------- #

def similarity(a, b):
    return SequenceMatcher(None, a.lower(), b.lower()).ratio()

def find_previous_feedback(question):
    conn = sqlite3.connect("assistant.db")
    c = conn.cursor()

    c.execute("SELECT question, answer, rating FROM feedback")
    rows = c.fetchall()

    conn.close()

    best = None
    best_score = 0

    for q, ans, rating in rows:
        score = similarity(question, q)
        if score > best_score:
            best_score = score
            best = (q, ans, rating)

    if best_score > 0.75:
        return best

    return None

# ---------------- ROUTES ---------------- #

@app.route("/")
def home():
    return "Backend is running!"

# Ask AI
@app.route("/ask", methods=["POST"])
def ask():

    data = request.get_json()

    question = data.get("question","")

    previous = find_previous_feedback(question)

    prompt = question

    if previous:
        _, _, rating = previous

        if rating.lower() == "bad":
            prompt = f"""
The previous explanation for this question was confusing.

Please explain like you're talking to a senior citizen who has never used a smartphone.

Use:
- Very simple English
- Numbered steps
- No technical jargon

Question:
{question}
"""

    response = client.models.generate_content(
        model="gemini-2.5-flash",
        contents=prompt
    )

    return jsonify({
        "answer": response.text
    })

# Save feedback
@app.route("/feedback", methods=["POST"])
def feedback():

    data = request.get_json()

    question = data["question"]
    answer = data["answer"]
    rating = data["rating"]
    comments = data.get("comments","")

    conn = sqlite3.connect("assistant.db")
    c = conn.cursor()

    c.execute(
        "INSERT INTO feedback(question,answer,rating,comments) VALUES(?,?,?,?)",
        (question,answer,rating,comments)
    )

    conn.commit()
    conn.close()

    return jsonify({
        "message":"Feedback saved successfully."
    })

# FAQ
@app.route("/faq", methods=["GET"])
def faq():
    return jsonify(FAQ)

if __name__ == "__main__":
    app.run(debug=True)